# ====== Official Meraki Dashboard API (stable) ======
MERAKI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERAKI_NETWORK_ID=L_123456789012345678
MERAKI_API_BASE=https://api.meraki.com/api/v1
GUEST_SSID_NAME=Bearhouse.Sunsu_GUEST      # ชื่อ SSID guest (ว่าง = ทุก SSID)
CLIENT_TIMESPAN=86400                        # ดู client ย้อนหลังกี่วิ (86400 = 24 ชม.)

# ====== Internal dashboard scrape (unofficial, cookie หมดอายุได้) ======
# วิธีหา 2 ค่านี้: เปิด dashboard > Network-wide > Clients > คลิก client ที่ online
#   เปิด DevTools > Network > หา request "client_show/<id>" > Right click > Copy as cURL
#   - URL: ตัด <clientId> ออก ให้เหลือลงท้าย /client_show/
#   - Cookie: ก๊อปค่า header Cookie ทั้งก้อน
MERAKI_CLIENT_SHOW_URL=https://n123.meraki.com/YourOrg/n/aB3xYz/manage/usage/client_show/
MERAKI_DASH_COOKIE=dash_auth=...; two_factor_auth=...; _ga=...
MERAKI_DASH_HEADERS_JSON={}                   # header เพิ่มเติมถ้าจำเป็น เช่น {"X-CSRF-Token":"..."}
SCRAPE_CONCURRENCY=4

# ====== Poller ======
POLL_INTERVAL_MIN=5

# ====== Retention / auto-purge ======
RETENTION_DAYS=120           # เก็บกี่วัน (พ.ร.บ.คอมฯ ขั้นต่ำ 90 -> เผื่อ buffer 120)
AUTO_PURGE_ENABLED=false     # true = ลบ log เก่ากว่า RETENTION_DAYS อัตโนมัติทุกวัน
CLEANUP_HOUR=3               # ชั่วโมง (UTC) ที่รันลบ (3 UTC = 10 โมงเช้าไทย)

# ====== Syslog -> Synology (option) ======
SYSLOG_ENABLED=false
SYSLOG_HOST=192.168.0.6
SYSLOG_PORT=514
SYSLOG_PROTO=udp          # udp | tcp
SYSLOG_TAG=meraki-guest-audit

# ====== Storage ======
DB_PATH=/data/guest_audit.db
